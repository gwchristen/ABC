<UserControl x:Class="ABC.Views.BluetoothLiveView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:ABC.Converters"
             xmlns:vm="clr-namespace:ABC.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:BluetoothLiveViewModel}"
             Background="{DynamicResource WindowBackground}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Left Panel: Bluetooth Settings ===== -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- Connection Type Card -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Connection Type" Style="{StaticResource SectionHeader}" />
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Content="SPP (COM Port)"
                                     IsChecked="{Binding IsSppMode, Mode=OneWay}"
                                     IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBool}}"
                                     Margin="0,0,16,0"
                                     VerticalAlignment="Center" />
                        <RadioButton Content="BLE"
                                     IsChecked="{Binding IsBleMode}"
                                     IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBool}}"
                                     Margin="0,0,16,0"
                                     VerticalAlignment="Center" />
                        <RadioButton Content="HID (Keyboard)"
                                     IsChecked="{Binding IsHidMode}"
                                     IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBool}}"
                                     VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- SPP Connection Card -->
            <Border Style="{StaticResource CardBorder}"
                    Visibility="{Binding IsSppMode, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="SPP Connection" Style="{StaticResource SectionHeader}" />

                    <!-- Connection status -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Style="{StaticResource StatusDot}" />
                        <TextBlock VerticalAlignment="Center" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Disconnected" />
                                    <Setter Property="Foreground" Value="#CC0000" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="Connected" />
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Port Selection -->
                    <TextBlock Text="COM Port:" Style="{StaticResource InfoLabel}" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding AvailablePorts}"
                                  SelectedItem="{Binding SelectedPort}"
                                  IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBool}}" />
                        <Button Grid.Column="2"
                                Content="↻"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding RefreshPortsCommand}"
                                MinWidth="36" Padding="8,6"
                                IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBool}}" />
                    </Grid>

                    <!-- Baud Rate (display only) -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Baud Rate:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Column="2" Text="115200" Style="{StaticResource InfoValue}" />
                    </Grid>

                    <!-- Connect / Disconnect buttons -->
                    <Button Content="Connect"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ConnectCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />

                    <Button Content="Disconnect"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding DisconnectCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}" />

                    <!-- Scan Count -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Scan Count:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Column="2" Text="{Binding BarcodeCount}" Style="{StaticResource InfoValue}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- BLE Connection Card -->
            <Border Style="{StaticResource CardBorder}"
                    Visibility="{Binding IsBleMode, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="BLE Connection" Style="{StaticResource SectionHeader}" />

                    <!-- Connection status -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Style="{StaticResource StatusDot}" />
                        <TextBlock VerticalAlignment="Center" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Disconnected" />
                                    <Setter Property="Foreground" Value="#CC0000" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Text" Value="Connected" />
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Scan button -->
                    <Button HorizontalAlignment="Stretch"
                            Margin="0,0,0,8"
                            Command="{Binding ScanBleCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButton}">
                                <Setter Property="Content" Value="Scan for Devices" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsScanningBle}" Value="True">
                                        <Setter Property="Content" Value="Stop Scanning" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- BLE device list -->
                    <TextBlock Text="Discovered Devices:" Style="{StaticResource InfoLabel}" Margin="0,0,0,4" />
                    <ComboBox Style="{StaticResource ModernComboBox}"
                              ItemsSource="{Binding BleDevices}"
                              SelectedItem="{Binding SelectedBleDevice}"
                              DisplayMemberPath="DisplayName"
                              IsEnabled="{Binding IsConnected, Converter={StaticResource InverseBool}}"
                              Margin="0,0,0,8" />

                    <!-- Connect / Disconnect buttons -->
                    <Button Content="Connect"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ConnectBleCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />

                    <Button Content="Disconnect"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding DisconnectCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}" />

                    <!-- Scan Count -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Scan Count:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Column="2" Text="{Binding BarcodeCount}" Style="{StaticResource InfoValue}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- HID Connection Card -->
            <Border Style="{StaticResource CardBorder}"
                    Visibility="{Binding IsHidMode, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="HID Connection" Style="{StaticResource SectionHeader}" />

                    <!-- Connection status -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <Ellipse Style="{StaticResource StatusDot}" />
                        <TextBlock VerticalAlignment="Center" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Not Listening" />
                                    <Setter Property="Foreground" Value="#CC0000" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsHidListening}" Value="True">
                                            <Setter Property="Text" Value="Listening" />
                                            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <!-- Start / Stop Listening button -->
                    <Button HorizontalAlignment="Stretch"
                            Margin="0,0,0,8"
                            Command="{Binding ToggleHidCommand}">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                <Setter Property="Content" Value="Start Listening" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsHidListening}" Value="True">
                                        <Setter Property="Content" Value="Stop Listening" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <!-- Info note -->
                    <TextBlock TextWrapping="Wrap" FontSize="11" Margin="0,0,0,8"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Text="Scanner must be paired in Windows Bluetooth settings and set to HID mode. Barcodes will be captured as keyboard input." />

                    <!-- Focus warning -->
                    <Border Background="#FFF3CD" BorderBrush="#FFC107" BorderThickness="1"
                            CornerRadius="4" Padding="8,6" Margin="0,0,0,8"
                            Visibility="{Binding ShowFocusWarning, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock TextWrapping="Wrap" FontSize="11"
                                   Foreground="#856404"
                                   Text="⚠ Window is not focused. Click the app window to capture scanner input." />
                    </Border>

                    <!-- Scan Count -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Scan Count:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Column="2" Text="{Binding BarcodeCount}" Style="{StaticResource InfoValue}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Options Card -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Display Options" Style="{StaticResource SectionHeader}" />
                    <CheckBox Content="Show timestamps"
                              IsChecked="{Binding ShowTimestamps}"
                              Margin="0,0,0,4" />
                </StackPanel>
            </Border>

            <!-- Save Options Card -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Save Options" Style="{StaticResource SectionHeader}" />

                    <!-- Directory -->
                    <TextBlock Text="Directory:" Style="{StaticResource InfoLabel}" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="2"
                                Content="..."
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseDirectoryCommand}"
                                MinWidth="36" Padding="8,6" />
                    </Grid>

                    <!-- Filename -->
                    <TextBlock Text="Filename:" Style="{StaticResource InfoLabel}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8" />

                    <!-- Format -->
                    <TextBlock Text="Format:" Style="{StaticResource InfoLabel}" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton Content=".txt" IsChecked="{Binding SaveAsCsv, Converter={StaticResource InverseBool}}"
                                     Margin="0,0,12,0" VerticalAlignment="Center" />
                        <RadioButton Content=".csv" IsChecked="{Binding SaveAsCsv}"
                                     VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Append to file -->
                    <CheckBox Content="Append to file"
                              IsChecked="{Binding AppendToFile}"
                              Margin="0,0,0,8" />

                    <!-- Append file picker - visible only when AppendToFile is checked -->
                    <StackPanel Visibility="{Binding AppendToFile, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,4,0,8">
                        <TextBlock Text="Append to:" Style="{StaticResource InfoLabel}" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding AppendFileName, Mode=OneWay}"
                                     Style="{StaticResource ModernTextBox}"
                                     IsReadOnly="True"
                                     ToolTip="{Binding AppendFilePath}" />
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Command="{Binding BrowseAppendFileCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0" />
                        </Grid>
                    </StackPanel>

                    <Button Content="Save"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding SaveCommand}"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}" />

        <!-- ===== Right Panel: Live Scan View ===== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="Live Scan Feed"
                           Style="{StaticResource SectionHeader}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <TextBlock Text="{Binding BarcodeCount, StringFormat='{}{0} barcode(s)'}"
                           Style="{StaticResource InfoLabel}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding DuplicateCount, StringFormat='{}{0} duplicate(s)'}"
                           Foreground="{DynamicResource WarningBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Visibility="{Binding HasDuplicates, Converter={StaticResource BoolToVisibility}}" />
                <TextBlock Text="{Binding InvalidLengthCount, StringFormat='{}{0} invalid length'}"
                           Foreground="#D83B01"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Visibility="{Binding HasInvalidLength, Converter={StaticResource BoolToVisibility}}" />
                <Button Content="Clear"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearDisplayCommand}"
                        Padding="8,4" FontSize="12"
                        Margin="8,0,0,0" />
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0">
                <TextBox Text="{Binding LiveText, Mode=OneWay}"
                         IsReadOnly="True"
                         TextWrapping="NoWrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         FontFamily="Consolas, Courier New"
                         FontSize="13"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="4"
                         x:Name="LiveTextBox" />
            </Border>
        </Grid>
    </Grid>
</UserControl>
