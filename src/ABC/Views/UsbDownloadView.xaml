<UserControl x:Class="ABC.Views.UsbDownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:ABC.Converters"
             xmlns:vm="clr-namespace:ABC.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:UsbDownloadViewModel}"
             Background="{DynamicResource WindowBackground}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Left Panel: Scanner Info ===== -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- Scanner Detection Card -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Scanner Detection" Style="{StaticResource SectionHeader}" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding AvailablePorts}"
                                  SelectedItem="{Binding SelectedPort}"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}"
                                  ToolTip="Select the COM port for the connected scanner">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat='COM {0}'}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="2"
                                Content="Detect"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding DetectScannersCommand}"
                                ToolTip="Scan USB ports for connected Opticon scanners" />
                    </Grid>

                    <Button Content="Preview / Download"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding PreviewCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            ToolTip="Connect to the selected scanner and download stored barcodes" />

                    <Button Content="Clear Scanner Data"
                            Style="{StaticResource DangerButton}"
                            Command="{Binding ClearScannerDataCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="Permanently erase all barcode data from the scanner's memory" />

                    <Button Content="Disconnect"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding DisconnectCommand}"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="Disconnect from the scanner and release the COM port" />
                </StackPanel>
            </Border>

            <!-- Scanner Info Card -->
            <Border Style="{StaticResource CardBorder}"
                    Visibility="{Binding ScannerInfo, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Scanner Info" Style="{StaticResource SectionHeader}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="24" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Model:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ScannerInfo.Model}" Style="{StaticResource InfoValue}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Firmware:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ScannerInfo.FirmwareVersion}" Style="{StaticResource InfoValue}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Serial:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding ScannerInfo.SerialNumber}" Style="{StaticResource InfoValue}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Battery:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding ScannerInfo.BatteryStatus}" Style="{StaticResource InfoValue}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Barcodes:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding ScannerInfo.BarcodeCount}" Style="{StaticResource InfoValue}" />

                        <TextBlock Grid.Row="5" Grid.Column="0" Text="COM Port:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Row="5" Grid.Column="2" Text="{Binding ScannerInfo.ComPort, StringFormat='COM {0}'}" Style="{StaticResource InfoValue}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Save Options Card -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Save Options" Style="{StaticResource SectionHeader}" />

                    <!-- Directory -->
                    <TextBlock Text="Directory:" Style="{StaticResource InfoLabel}" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding SaveDirectory, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="Folder where the file will be saved" />
                        <Button Grid.Column="2"
                                Content="..."
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding BrowseDirectoryCommand}"
                                MinWidth="36" Padding="8,6" />
                    </Grid>

                    <!-- Filename -->
                    <TextBlock Text="Filename:" Style="{StaticResource InfoLabel}" Margin="0,0,0,4" />
                    <TextBox Style="{StaticResource ModernTextBox}"
                             Text="{Binding FileName, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,0,8"
                             ToolTip="Name for the saved file (without extension)" />

                    <!-- Format -->
                    <TextBlock Text="Format:" Style="{StaticResource InfoLabel}" Margin="0,0,0,4" />
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <RadioButton Content=".txt" IsChecked="{Binding SaveAsCsv, Converter={StaticResource InverseBool}}"
                                     Margin="0,0,12,0" VerticalAlignment="Center"
                                     ToolTip="Save as plain text with one barcode per line" />
                        <RadioButton Content=".csv" IsChecked="{Binding SaveAsCsv}"
                                     VerticalAlignment="Center"
                                     ToolTip="Save in comma-separated format for spreadsheet import" />
                    </StackPanel>

                    <!-- Clear after save -->
                    <CheckBox Content="Clear scanner data after save"
                              IsChecked="{Binding ClearAfterSave}"
                              Margin="0,0,0,8"
                              ToolTip="Automatically clear scanner data after a successful save" />

                    <!-- Append to file -->
                    <CheckBox Content="Append to file"
                              IsChecked="{Binding AppendToFile}"
                              Margin="0,0,0,8"
                              ToolTip="Add barcodes to the end of an existing file instead of creating a new one" />

                    <!-- Append file picker - visible only when AppendToFile is checked -->
                    <StackPanel Visibility="{Binding AppendToFile, Converter={StaticResource BoolToVisibility}}"
                                Margin="0,4,0,8">
                        <TextBlock Text="Append to:" Style="{StaticResource InfoLabel}" Margin="0,0,0,4" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{Binding AppendFileName, Mode=OneWay}"
                                     Style="{StaticResource ModernTextBox}"
                                     IsReadOnly="True"
                                     ToolTip="{Binding AppendFilePath}" />
                            <Button Grid.Column="1"
                                    Content="Browse..."
                                    Command="{Binding BrowseAppendFileCommand}"
                                    Style="{StaticResource SecondaryButton}"
                                    Margin="8,0,0,0"
                                    ToolTip="Select the existing file to append barcodes to" />
                        </Grid>
                    </StackPanel>

                    <Button Content="Save"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding SaveCommand}"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}" />

        <!-- ===== Right Panel: Barcode Preview ===== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Row 0: Title, counts, busy indicator -->
            <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Barcode Preview"
                           Style="{StaticResource SectionHeader}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <TextBlock Text="{Binding Barcodes.Count, StringFormat='{}{0} barcode(s)'}"
                           Style="{StaticResource InfoLabel}"
                           VerticalAlignment="Center" />
                <TextBlock Text="{Binding DuplicateCount, StringFormat='{}{0} duplicate(s)'}"
                           Foreground="{DynamicResource WarningBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Visibility="{Binding HasDuplicates, Converter={StaticResource BoolToVisibility}}"
                           ToolTip="This barcode appears more than once in the scan data" />
                <TextBlock Text="{Binding InvalidLengthCount, StringFormat='{}{0} invalid length'}"
                           Foreground="#D83B01"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Visibility="{Binding HasInvalidLength, Converter={StaticResource BoolToVisibility}}"
                           ToolTip="Barcode length doesn't match the expected format" />
                <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} selected'}"
                           Foreground="{DynamicResource AccentBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"
                           Visibility="{Binding HasSelected, Converter={StaticResource BoolToVisibility}}" />
                <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                             Margin="12,0,0,0" VerticalAlignment="Center"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
            </WrapPanel>

            <!-- Row 1: Action buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,4">
                <Button Content="Remove Selected"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding RemoveSelectedCommand}"
                        VerticalAlignment="Center"
                        Visibility="{Binding HasSelected, Converter={StaticResource BoolToVisibility}}" />
                <Button Content="Clear Selection"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ClearSelectionCommand}"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        Visibility="{Binding HasSelected, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>

            <Border Grid.Row="2" Style="{StaticResource CardBorder}" Margin="0">
                <DataGrid x:Name="BarcodeGrid"
                          Style="{StaticResource ModernDataGrid}"
                          SelectionMode="Extended"
                          ItemsSource="{Binding Barcodes}"
                          RowStyle="{StaticResource DuplicateRowStyle}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Width="40" IsReadOnly="False">
                            <DataGridTemplateColumn.HeaderTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding DataContext.IsAllSelected,
                                                          RelativeSource={RelativeSource AncestorType=DataGrid},
                                                          Mode=TwoWay}"
                                              IsThreeState="True"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.HeaderTemplate>
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="#" Binding="{Binding SequenceNumber}" Width="50" />
                        <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="*" />
                        <DataGridTextColumn Header="Code Type" Binding="{Binding CodeType}" Width="100" />
                        <DataGridTextColumn Header="Timestamp" Binding="{Binding Timestamp, StringFormat='yyyy-MM-dd HH:mm:ss'}" Width="160" />
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusText}" Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>