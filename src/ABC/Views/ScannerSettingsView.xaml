<UserControl x:Class="ABC.Views.ScannerSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:ABC.Converters"
             xmlns:vm="clr-namespace:ABC.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:ScannerSettingsViewModel}"
             Background="{DynamicResource WindowBackground}">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </UserControl.Resources>

    <Grid Margin="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ===== Left Panel ===== -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>

            <!-- Scanner Detection Card -->
            <Border Style="{StaticResource CardBorder}">
                <StackPanel>
                    <TextBlock Text="Scanner Detection" Style="{StaticResource SectionHeader}" />

                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="4" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding AvailablePorts}"
                                  SelectedItem="{Binding SelectedPort}"
                                  IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding StringFormat='COM {0}'}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Grid.Column="2"
                                Content="Detect"
                                Style="{StaticResource SecondaryButton}"
                                Command="{Binding DetectScannersCommand}" />
                    </Grid>

                    <Button Content="Connect"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding ConnectCommand}"
                            HorizontalAlignment="Stretch"
                            Margin="0,0,0,4" />

                    <Button Content="Disconnect"
                            Style="{StaticResource SecondaryButton}"
                            Command="{Binding DisconnectCommand}"
                            HorizontalAlignment="Stretch"
                            Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
            </Border>

            <!-- Scanner Info Card (visible only when connected) -->
            <Border Style="{StaticResource CardBorder}"
                    Visibility="{Binding ScannerInfo, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="Scanner Info" Style="{StaticResource SectionHeader}" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="24" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="24" />
                            <RowDefinition Height="24" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Model:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Row="0" Grid.Column="2" Text="{Binding ScannerInfo.Model}" Style="{StaticResource InfoValue}" />

                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Firmware:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding ScannerInfo.FirmwareVersion}" Style="{StaticResource InfoValue}" />

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Serial:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="{Binding ScannerInfo.SerialNumber}" Style="{StaticResource InfoValue}" />

                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Battery:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Row="3" Grid.Column="2" Text="{Binding ScannerInfo.BatteryStatus}" Style="{StaticResource InfoValue}" />

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="COM Port:" Style="{StaticResource InfoLabel}" />
                        <TextBlock Grid.Row="4" Grid.Column="2" Text="{Binding ScannerInfo.ComPort, StringFormat='COM {0}'}" Style="{StaticResource InfoValue}" />
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
        </ScrollViewer>

        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                      Background="{DynamicResource BorderBrush}" />

        <!-- ===== Right Panel: Settings ===== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header row -->
            <WrapPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="Scanner Settings"
                           Style="{StaticResource SectionHeader}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <ProgressBar IsIndeterminate="True" Width="120" Height="4"
                             Margin="4,0,0,0" VerticalAlignment="Center"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}" />
            </WrapPanel>

            <!-- Action buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8">
                <Button Content="Read All"
                        Style="{StaticResource SecondaryButton}"
                        Command="{Binding ReadAllCommand}"
                        Margin="0,0,4,0" />
                <Button Content="Apply All"
                        Style="{StaticResource AccentButton}"
                        Command="{Binding ApplyAllCommand}"
                        Margin="0,0,4,0" />
                <Button Content="Reset to Defaults"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding ResetDefaultsCommand}" />
            </StackPanel>

            <!-- Not connected message -->
            <TextBlock Grid.Row="2"
                       Text="Connect a scanner to configure settings."
                       Style="{StaticResource InfoLabel}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}, ConverterParameter=Invert}" />

            <!-- Settings card (visible only when connected) -->
            <Border Grid.Row="2"
                    Style="{StaticResource CardBorder}"
                    Margin="0"
                    Visibility="{Binding IsConnected, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel IsEnabled="{Binding IsConnected}">

                    <!-- Param 2: Buzzer -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Buzzer:" Style="{StaticResource InfoLabel}" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding BuzzerEnabled}" VerticalAlignment="Center"
                                  Content="Enable beep on scan" />
                    </Grid>

                    <!-- Param 10: Host Connect Beep -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Host Connect Beep:" Style="{StaticResource InfoLabel}" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding HostConnectBeepEnabled}" VerticalAlignment="Center"
                                  Content="Beep when connected to host" />
                    </Grid>

                    <!-- Param 11: Host Complete Beep -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Host Complete Beep:" Style="{StaticResource InfoLabel}" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding HostCompleteBeepEnabled}" VerticalAlignment="Center"
                                  Content="Beep on upload complete" />
                    </Grid>

                    <!-- Param 35: Store RTC Timestamp -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Store RTC Timestamp:" Style="{StaticResource InfoLabel}" VerticalAlignment="Center" />
                        <CheckBox Grid.Column="1" IsChecked="{Binding StoreTimestampEnabled}" VerticalAlignment="Center"
                                  Content="Store timestamp with each scan" />
                    </Grid>

                    <Separator Margin="0,4,0,12" Background="{DynamicResource BorderBrush}" />

                    <!-- Param 4: Reject Redundant Barcode -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Reject Redundant Barcode:" Style="{StaticResource InfoLabel}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding RejectRedundantOptions}"
                                  SelectedIndex="{Binding RejectRedundantIndex}" />
                    </Grid>

                    <!-- Param 7: Low-Battery Indication -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="200" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Low-Battery Indication:" Style="{StaticResource InfoLabel}" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Style="{StaticResource ModernComboBox}"
                                  ItemsSource="{Binding LowBatteryOptions}"
                                  SelectedIndex="{Binding LowBatteryIndex}" />
                    </Grid>

                    <Separator Margin="0,4,0,12" Background="{DynamicResource BorderBrush}" />

                    <!-- Param 17: Scanner On-Time -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Scanner On-Time:" Style="{StaticResource InfoLabel}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding ScannerOnTime, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2" Text="(1–255 seconds)" Style="{StaticResource InfoLabel}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </Grid>

                    <!-- Param 34: Max Barcode Length -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="80" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Max Barcode Length:" Style="{StaticResource InfoLabel}" VerticalAlignment="Center" />
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource ModernTextBox}"
                                 Text="{Binding MaxBarcodeLength, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Grid.Column="2" Text="(1–30 characters)" Style="{StaticResource InfoLabel}" VerticalAlignment="Center" Margin="8,0,0,0" />
                    </Grid>

                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
