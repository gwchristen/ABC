<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Dark Theme Colors ===== -->
    <Color x:Key="AccentColor">#0078D4</Color>
    <Color x:Key="AccentHoverColor">#106EBE</Color>
    <Color x:Key="AccentPressedColor">#005A9E</Color>
    <Color x:Key="BackgroundColor">#1E1E1E</Color>
    <Color x:Key="SurfaceColor">#2D2D2D</Color>
    <Color x:Key="CardColor">#2D2D2D</Color>
    <Color x:Key="BorderColor">#404040</Color>
    <Color x:Key="TextPrimaryColor">#E0E0E0</Color>
    <Color x:Key="TextSecondaryColor">#A0A0A0</Color>
    <Color x:Key="StatusBarBgColor">#1A1A1A</Color>
    <Color x:Key="StatusBarFgColor">#E0E0E0</Color>
    <Color x:Key="SuccessColor">#107C10</Color>
    <Color x:Key="WarningColor">#D83B01</Color>

    <!-- ===== Dark Theme Brushes ===== -->
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="{StaticResource AccentPressedColor}" />
    <SolidColorBrush x:Key="WindowBackground" Color="{StaticResource BackgroundColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="StatusBarBackground" Color="{StaticResource StatusBarBgColor}" />
    <SolidColorBrush x:Key="StatusBarForeground" Color="{StaticResource StatusBarFgColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="AlternatingRowBrush" Color="#3D3D3D" />
    <SolidColorBrush x:Key="DuplicateHighlightBrush" Color="#5C4A00" />
    <SolidColorBrush x:Key="InvalidLengthHighlightBrush" Color="#5C1A1A" />

</ResourceDictionary>
